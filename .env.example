# === ОБЯЗАТЕЛЬНЫЕ ===

# Токен бота lolka.app (создать: https://lolka.app/developers/bots)
LOLKA_TOKEN_YM=твой_токен_бота_с_lolka.app

# Токен Яндекс.Музыки (заполняется автоматически через setup.mjs или вручную)
# YM_TOKEN=

# === ОПЦИОНАЛЬНЫЕ ===

# Cookie Session_id для скачивания полных треков без подписки Plus
# YM_SESSION_ID=

# ID голосового канала для автоподключения при старте
# MUSIC_CHANNEL_ID=
